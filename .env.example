# Vertex AI (Google Cloud)
VERTEX_PROJECT_ID=my-project-id
VERTEX_LOCATION=us-central1
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# JWT - rastgele güçlü bir string (en az 32 karakter)
JWT_SECRET=guclu-rastgele-bir-sifre-buraya-yazin-32-karakter

# Vercel Postgres - Vercel Dashboard > Storage > Create Database > Postgres
# Otomatik eklenir, elle girmenize gerek yoktur
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
