# Google Cloud Vertex AI ayarları
# Google Cloud Console: https://console.cloud.google.com

# Proje ID (Google Cloud Console'dan)
VERTEX_PROJECT_ID=my-project-id

# Bölge (genellikle us-central1)
VERTEX_LOCATION=us-central1

# Service Account JSON (tek satır olarak)
# IAM > Service Accounts > Anahtar Oluştur > JSON > içeriği buraya yapıştır
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
