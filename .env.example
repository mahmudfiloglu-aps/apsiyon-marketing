# Gemini API Key - https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# JWT - rastgele güçlü bir string (en az 32 karakter)
JWT_SECRET=guclu-rastgele-bir-sifre-buraya-yazin-32-karakter

# Neon Postgres - Neon Dashboard > Connection Details > Connection string (unpooled)
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require
